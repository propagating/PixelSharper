# Normalize line endings: store text as LF in the repo and check out as LF everywhere
# (consistent across Windows/Linux/CI; stops the recurring "LF will be replaced by CRLF" churn).
* text=auto eol=lf

# Explicit text types
*.cs      text eol=lf
*.csproj  text eol=lf
*.sln     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.linq    text eol=lf
*.h       text eol=lf
*.cpp     text eol=lf
*.txt     text eol=lf

# Binary assets — never normalize
*.png  binary
*.jpg  binary
*.dll  binary
*.exe  binary
*.nupkg binary
*.snupkg binary
*.spr  binary
